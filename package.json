{
  "name": "n-ext-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "n-ext — Next.js Server DevTools monorepo",
  "license": "MIT",
  "author": "Anuj",
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "pnpm -r build",
    "build:n-ext": "cd packages/n-ext && pnpm build",
    "build:extension": "cd packages/extension && pnpm build",
    "dev": "cd apps/demo && pnpm dev",
    "publish:n-ext": "cd packages/n-ext && npm publish --access public"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
